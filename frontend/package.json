{
  "name": "hassette-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "types": "openapi-typescript openapi.json -o src/api/generated-types.ts",
    "ws-types": "node ../scripts/generate-ws-types.cjs",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,css}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,css}'",
    "size": "npm run build && size-limit"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@preact/signals": "^2.9.2",
    "@tanstack/preact-query": "^5.101.2",
    "ajv": "^8.20.0",
    "clsx": "^2.1.1",
    "preact": "^10.29.0",
    "shiki": "^4.3.0",
    "sonner": "^2.0.7",
    "wouter": "^3.10.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@preact/preset-vite": "^2.10.5",
    "@size-limit/file": "^12.0.0",
    "@testing-library/preact": "^3.2.4",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "jsdom": "^29.1.1",
    "json-schema-to-typescript": "^15.0.4",
    "msw": "^2.14.6",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.9.3",
    "size-limit": "^12.0.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.2",
    "vite-css-modules": "^1.16.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "openapi-typescript": {
      "typescript": "$typescript"
    }
  }
}
